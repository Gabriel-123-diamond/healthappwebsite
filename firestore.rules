rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userIsAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function userIsExpert() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['doctor', 'herbal_practitioner', 'hospital', 'expert'];
    }

    // Public collections (accessible by guests)
    match /feed_items/{itemId} {
      allow read: if true;
      allow write: if false; 
    }

    match /experts/{expertId} {
      allow read: if true;
      allow write: if userIsAdmin();
    }

    match /institutions/{instId} {
      allow read: if true;
      allow write: if userIsAdmin();
    }

    match /learningPaths/{pathId} {
      allow read: if true;
      allow write: if userIsAdmin();
    }

    match /learning_paths/{pathId} {
      allow read: if true;
      allow write: if userIsAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow write: if userIsAdmin();
    }

    match /community_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.authorId && request.resource.data.authorId == request.auth.uid) || 
        userIsAdmin()
      );
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || userIsAdmin());

      match /answers/{answerId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || userIsAdmin());
      }
    }

    match /polls/{pollId} {
      allow read: if true;
      allow write: if userIsAdmin();
    }

    match /safety_config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // User-specific collections
    match /users/{userId} {
      // Owner or Admin can read
      // Experts can only read if they have an active appointment with this user (Privacy improvement)
      allow read: if isOwner(userId) || userIsAdmin() || (
        userIsExpert() && 
        exists(/databases/$(database)/documents/appointments/$(request.auth.uid + "_" + userId))
      ); 
      
      // Strict write rules
      allow create: if isOwner(userId) && 
        request.resource.id == request.auth.uid &&
        request.resource.data.role != 'admin' &&
        (!('points' in request.resource.data) || request.resource.data.points == 0) &&
        request.resource.data.onboardingComplete == false;
        
      allow update: if isOwner(userId) && (
        // Case 1: Reverting to sign-up/onboarding (Allow deleting role if not verified)
        (
          request.resource.data.onboardingComplete == false &&
          (!('verificationStatus' in resource.data) || resource.data.verificationStatus != 'verified') &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['role', 'expertProfile', 'onboardingStep', 'onboardingComplete', 'specialty', 'licenseNumber', 'institutionName', 'updatedAt', 'specialties', 'yearsOfExperience', 'profileComplete'])
        ) ||
        // Case 2: Normal profile updates (Prevent privilege escalation)
        (
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'points', 'verificationStatus', 'emailVerified', 'phoneVerified'])
        )
      );

      // Admin can update anything
      allow write: if userIsAdmin();

      // Subcollections (Private by default)
      match /bookmarks/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /history/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /searchHistory/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /saved_searches/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /journals/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /learning_progress/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /journals/{journalId} {
      allow read, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || userIsAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid) || 
        userIsAdmin()
      );
    }

    match /referral_codes/{userId} {
      allow read: if true; 
      allow write: if isOwner(userId);
    }

    match /referrals/{referralId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.referrerUid || 
        request.auth.uid == resource.data.inviteeUid
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.inviteeUid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.inviteeUid &&
        request.resource.data.status == 'completed' &&
        resource.data.status == 'pending' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'completedAt']) &&
        request.resource.data.referrerUid == resource.data.referrerUid &&
        request.resource.data.inviteeUid == resource.data.inviteeUid
      );
    }

    match /reviews/{reviewId} {
      allow read: if true; 
      allow create: if userIsExpert() && request.resource.data.expertId == request.auth.uid;
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.expertId && request.resource.data.expertId == request.auth.uid) || 
        userIsAdmin()
      );
      allow delete: if userIsAdmin();
    }

    match /api_keys/{keyId} {
      allow read, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid) || 
        userIsAdmin()
      );
    }

    match /verification_requests/{requestId} {
      allow read: if userIsAdmin() || (isSignedIn() && resource.data.expertId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.expertId == request.auth.uid;
      allow update, delete: if userIsAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.expertId || 
        userIsAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid; 
      allow update: if isSignedIn() && (
        (
          (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.expertId) &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.expertId == resource.data.expertId
        ) || 
        userIsAdmin()
      );
      allow delete: if userIsAdmin();
    }

    match /consultation_notes/{noteId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.expertId || 
        userIsAdmin()
      );
      allow create: if userIsExpert();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.expertId || 
        userIsAdmin()
      );
      allow delete: if userIsAdmin();
    }
    
    match /global_history/{docId} {
      allow read: if userIsAdmin() || userIsExpert();
      allow create: if false; 
      allow write: if userIsAdmin();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || userIsAdmin());
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || userIsAdmin());
      allow delete: if userIsAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || userIsAdmin());
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow update, delete: if userIsAdmin();
      }
    }
    
    match /expert_stats/{expertId} {
      allow read: if true;
      allow write: if userIsAdmin() || (isSignedIn() && request.auth.uid == expertId);
    }
    
    match /expert_content/{contentId} {
      allow read: if true;
      allow write: if userIsAdmin() || (isSignedIn() && request.resource.data.expertId == request.auth.uid);
    }
  }
}
