rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userIsAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function userIsExpert() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['doctor', 'herbal_practitioner', 'hospital'];
    }

    // Discovery collections (accessible by guests for public preview)
    match /feed_items/{document=**} {
      allow read: if true;
      allow write: if false; 
    }

    match /experts/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /institutions/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /learningPaths/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /articles/{docId} {
      allow read: if true;
      allow create: if userIsExpert() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if userIsAdmin() || (userIsExpert() && resource.data.authorId == request.auth.uid);
    }

    match /learning_paths/{docId} {
      allow read: if isSignedIn();
      allow create: if userIsExpert() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if userIsAdmin() || (userIsExpert() && resource.data.authorId == request.auth.uid);
    }

    match /polls/{docId} {
      allow read: if isSignedIn();
      allow write: if userIsAdmin();
    }

    match /users/{userId} {
      // Owner or Admin can read specific documents
      allow get: if isOwner(userId) || userIsAdmin() || (
        userIsExpert() && 
        exists(/databases/$(database)/documents/appointments/$(request.auth.uid + "_" + userId))
      );
      
      // Removed list access: use secure /api/user/check instead to prevent scraping
      
      // Strict write rules
      allow create: if isOwner(userId) && 
        request.resource.id == request.auth.uid &&
        request.resource.data.get('role', 'user') != 'admin' &&
        request.resource.data.get('points', 0) == 0 &&
        request.resource.data.get('onboardingComplete', false) == false;
        
      allow update: if isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'points', 'emailVerified', 'phoneVerified', 'verificationStatus', 'tier', 'onboardingComplete'])
      );

      // Admin can update anything
      allow write: if userIsAdmin();

      // Subcollections (Private by default)
      match /bookmarks/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /history/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /searchHistory/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /saved_searches/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /journals/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /journals/{journalId} {
      // Ensure only the owner can access journals
      allow read, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || userIsAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid) || 
        userIsAdmin()
      );
    }

    match /referral_codes/{userId} {
      allow read: if isSignedIn(); 
      allow write: if false; // Must use /api/referral/generate
    }

    match /referrals/{referralId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.referrerUid || 
        request.auth.uid == resource.data.inviteeUid ||
        userIsAdmin()
      );
      allow write: if false; // Must use /api/referral/apply or complete
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn(); 
      allow create: if userIsExpert() && request.resource.data.expertId == request.auth.uid;
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.expertId && request.resource.data.expertId == request.auth.uid) || 
        userIsAdmin()
      );
      allow delete: if userIsAdmin();
    }

    match /safety_config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /api_keys/{keyId} {
      // Ensure users can only create and see their own API keys
      allow read, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid) || 
        userIsAdmin()
      );
    }

    match /verification_requests/{requestId} {
      allow read: if userIsAdmin() || (isSignedIn() && resource.data.expertId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.expertId == request.auth.uid;
      allow update, delete: if userIsAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.expertId || 
        userIsAdmin()
      );
      // Ensure creating user sets themselves as the userId
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid; 
      allow update: if isSignedIn() && (
        (
          (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.expertId) &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.expertId == resource.data.expertId
        ) || 
        userIsAdmin()
      );
      allow delete: if userIsAdmin();
    }

    match /consultation_notes/{noteId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.expertId || 
        userIsAdmin()
      );
      allow create: if userIsExpert();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.expertId || 
        userIsAdmin()
      );
      allow delete: if userIsAdmin();
    }
    
    match /global_history/{docId} {
      allow read: if userIsAdmin() || userIsExpert();
      allow create: if false; // Logged only via Admin SDK (Search API)
      allow write: if userIsAdmin();
    }

    match /access_codes/{codeId} {
      allow read: if isSignedIn();
      allow create: if userIsExpert() && request.resource.data.expertId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.expertId == request.auth.uid || userIsAdmin());
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || userIsAdmin());
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || userIsAdmin());
      allow delete: if userIsAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || userIsAdmin());
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow update, delete: if userIsAdmin();
      }
    }
  }
}
